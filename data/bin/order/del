#!/data/data/com.termux/files/usr/bin/bash
# Windows风格del命令 for Termux

# 显示帮助
show_help() {
    echo "Deletes one or more files."
    echo ""
    echo "DEL [/P] [/F] [/S] [/Q] [/A:attributes] names"
    echo ""
    echo "  names         Specifies a list of one or more files or directories."
    echo "                Wildcards may be used to delete multiple files."
    echo "  /P            Prompts for confirmation before deleting each file."
    echo "  /F            Force deleting of read-only files."
    echo "  /S            Delete specified files from all subdirectories."
    echo "  /Q            Quiet mode, do not ask if ok to delete on global wildcard"
    echo ""
    echo "  /?            Display this help message"
    echo ""
    echo "Examples:"
    echo "  del file.txt           # Delete a single file"
    echo "  del *.tmp /Q           # Delete all .tmp files quietly"
    echo "  del /S *.bak           # Delete .bak files from current and subdirectories"
}

# 检查参数
if [[ $# -eq 0 ]] || [[ "$1" == "/?" ]]; then
    show_help
    exit 0
fi

# 解析参数
prompt=false
force=false
recursive=false
quiet=false
files=()

for arg in "$@"; do
    case $arg in
        /P|/p)
            prompt=true
            ;;
        /F|/f)
            force=true
            ;;
        /S|/s)
            recursive=true
            ;;
        /Q|/q)
            quiet=true
            ;;
        *)
            files+=("$arg")
            ;;
    esac
done

# 构建rm命令参数
rm_args=()
if [ "$force" = true ]; then
    rm_args+=("-f")
fi
if [ "$recursive" = true ]; then
    rm_args+=("-r")
fi
if [ "$prompt" = true ]; then
    rm_args+=("-i")
elif [ "$quiet" = true ]; then
    rm_args+=("-f")
fi

# 执行删除
if [ ${#files[@]} -gt 0 ]; then
    rm "${rm_args[@]}" "${files[@]}"
else
    echo "Error: No files specified."
    exit 1
fi